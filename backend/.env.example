# ====================================
# 顺时 ShunShi - 环境变量模板 (.env.example)
# 复制为 .env 并填写实际值
# ====================================

# ==================== 通用 ====================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=4000
APP_SECRET_KEY=change-me-to-a-random-string
JWT_SECRET=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ==================== 数据库 ====================
# 开发环境: 留空使用 SQLite (data/shunshi.db)
# 生产环境: 填写 PostgreSQL URL
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://shunshi:your_password@localhost:5432/shunshi
# Docker: DATABASE_URL=postgresql+psycopg2://shunshi:shunshi123@postgres:5432/shunshi

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
# Docker: REDIS_URL=redis://redis:6379/0

# ==================== LLM ====================
SILICONFLOW_API_KEY=sk-xxx
OPENROUTER_API_KEY=

# ==================== 支付宝 (CN版) ====================
ALIPAY_MODE=mock
# mock: 模拟模式 (开发/测试)
# sandbox: 沙箱环境
# production: 生产环境
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://api.shunshi.cn/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://app.shunshi.cn/payment/success

# ==================== Stripe (GL版/国际版) ====================
STRIPE_MODE=mock
# mock: 模拟模式
# test: Stripe 测试模式
# live: Stripe 生产模式
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_SERENITY=
STRIPE_PRICE_HARMONY=
STRIPE_PRICE_FAMILY=

# ==================== FCM 推送 (Android) ====================
FCM_MODE=mock
# mock: 模拟模式
# production: 真实推送
FCM_PROJECT_ID=shunshi-push
FCM_CREDENTIALS_PATH=
# 或者直接 JSON 字符串:
# FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"shunshi-push",...}

# ==================== APNs 推送 (iOS) ====================
APNS_MODE=mock
# mock: 模拟模式
# production: 真实推送
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=care.seasons.shunshi
APNS_USE_SANDBOX=true
APNS_QUIET_START=22:00
APNS_QUIET_END=07:00

# ==================== 统一通知网关 ====================
NOTIFICATION_MODE=mock

# ==================== 监控 ====================
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==================== CORS ====================
CORS_ORIGINS=https://app.shunshi.cn,https://app.seasons.care

# ==================== Apple Sign-In ====================
APPLE_BUNDLE_ID=com.shunshi.app
APPLE_TEAM_ID=
APPLE_SERVICE_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
