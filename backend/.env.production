# ====================================
# 顺时 ShunShi - 生产环境配置模板 (.env.production)
# !! 请勿提交到 Git !!
# 复制为 .env 并填写实际值
# ====================================

# ==================== 通用 ====================
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=4000
APP_SECRET_KEY=<GENERATE-A-64-CHAR-RANDOM-STRING>
JWT_SECRET=<GENERATE-ANOTHER-64-CHAR-RANDOM-STRING>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ==================== 数据库 (PostgreSQL) ====================
DATABASE_URL=postgresql+psycopg2://shunshi:<DB_PASSWORD>@<DB_HOST>:5432/shunshi

# ==================== Redis ====================
REDIS_URL=redis://:<REDIS_PASSWORD>@<REDIS_HOST>:6379/0

# ==================== LLM ====================
SILICONFLOW_API_KEY=<YOUR_KEY>
OPENROUTER_API_KEY=<YOUR_KEY>

# ==================== 支付宝 (CN版) ====================
ALIPAY_MODE=production
ALIPAY_APP_ID=<YOUR_ALIPAY_APP_ID>
ALIPAY_PRIVATE_KEY=<YOUR_PRIVATE_KEY>
ALIPAY_PUBLIC_KEY=<YOUR_PUBLIC_KEY>
ALIPAY_NOTIFY_URL=https://api.shunshi.cn/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://app.shunshi.cn/payment/success

# ==================== Stripe (GL版/国际版) ====================
STRIPE_MODE=live
STRIPE_SECRET_KEY=sk_live_<YOUR_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_WEBHOOK_SECRET>
STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_PUBLISHABLE_KEY>
STRIPE_PRICE_SERENITY=price_<YOUR_SERENITY_PRICE_ID>
STRIPE_PRICE_HARMONY=price_<YOUR_HARMONY_PRICE_ID>
STRIPE_PRICE_FAMILY=price_<YOUR_FAMILY_PRICE_ID>

# ==================== FCM 推送 (Android) ====================
FCM_MODE=production
FCM_PROJECT_ID=shunshi-push
FCM_CREDENTIALS_PATH=/app/secrets/fcm-credentials.json

# ==================== APNs 推送 (iOS) ====================
APNS_MODE=production
APNS_KEY_ID=<YOUR_KEY_ID>
APNS_TEAM_ID=<YOUR_TEAM_ID>
APNS_KEY_PATH=/app/secrets/AuthKey_<KEY_ID>.p8
APNS_BUNDLE_ID=care.seasons.shunshi
APNS_USE_SANDBOX=false
APNS_QUIET_START=22:00
APNS_QUIET_END=07:00

# ==================== 统一通知网关 ====================
NOTIFICATION_MODE=production

# ==================== 监控 ====================
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=<GRAFANA_USER>
GRAFANA_ADMIN_PASSWORD=<GRAFANA_PASSWORD>

# ==================== CORS ====================
CORS_ORIGINS=https://app.shunshi.cn,https://app.seasons.care
